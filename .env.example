# ============================================================
# .env.example — Required Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your values in .env
#   3. NEVER commit .env to GitHub (it's in .gitignore)
#   4. For GitHub Actions, set these as repository secrets:
#      GitHub → Settings → Secrets and variables → Actions → New repository secret

# ── GitHub ────────────────────────────────────────────────
# Personal Access Token with repo read/write permissions
# Get one at: https://github.com/settings/tokens
# Required permissions: repo (full), workflow
GITHUB_TOKEN=your_github_personal_access_token_here

# Your repo in "username/repo-name" format
GITHUB_REPO=yourusername/phone-studio

# ── LLM APIs (optional — only needed for cloud fallback) ──
# Anthropic (Claude) — for lead routing and complex tasks
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — fallback for captions and ideas
OPENAI_API_KEY=sk-...

# Groq — fast free-tier option for daily testing
GROQ_API_KEY=gsk_...

# ── Phone Studio Dock (optional) ──────────────────────────
# Webhook URL for context sync notifications
# Set this to your Dock's local or tunnel endpoint
DOCK_WEBHOOK_URL=http://localhost:3001/webhook/context-update

# MCP server port (default: 8000)
PORT=8000
